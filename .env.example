# ============================================
# .env.example — Disfracesly PERN Stack
# Copiá este archivo a .env y completá los valores reales.
# NUNCA subas el archivo .env al repositorio.
# ============================================

# ----------------------------
# CONFIGURACIÓN DEL SERVIDOR (BACKEND)
# ----------------------------
PORT=5000
NODE_ENV=development

# ----------------------------
# BASE DE DATOS — Prisma (schema: gestion)
# La URL incluye ?schema=gestion para que Prisma use ese schema como search_path
# El trigger XOR y los enums están en el schema "gestion" (ultimate.sql)
# ----------------------------
DATABASE_URL="postgresql://postgres:tu_contraseña_aca@localhost:5432/disfracesly?schema=gestion"

# ----------------------------
# SEGURIDAD — JWT
# JWT_SECRET debe tener al menos 32 caracteres para pasar la validación Zod
# ----------------------------
JWT_SECRET=clave_secreta_super_segura_para_produccion_32chars
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ----------------------------
# IMÁGENES / UPLOADS
# ----------------------------
UPLOAD_DIR=uploads
MAX_FILE_SIZE=5242880

# ----------------------------
# FRONTEND (CORS)
# ----------------------------
FRONTEND_URL=http://localhost:3000

# ----------------------------
# FRONTEND — Variables Vite (prefijo VITE_ obligatorio)
# ----------------------------
VITE_API_URL=http://localhost:5000/api

# ----------------------------
# OPCIONAL — Debug de queries Prisma
# ----------------------------
LOG_QUERIES=false
