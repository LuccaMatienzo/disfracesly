generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["views", "omitApi"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model CategoriaMotivo {
  id_categoria_motivo BigInt                  @id @default(autoincrement())
  nombre              String                  @db.VarChar(100)
  descripcion         String?
  deleted_at          DateTime?
  imagenes            CategoriaMotivoImagen[]
  piezas              PiezaCategoria[]

  @@map("categoria_motivo")
}

model Pieza {
  id_pieza    BigInt           @id @default(autoincrement())
  nombre      String           @db.VarChar(100)
  descripcion String?
  deleted_at  DateTime?
  disfraces   DisfrazPieza[]
  categorias  PiezaCategoria[]
  imagenes    PiezaImagen[]
  stocks      PiezaStock[]

  @@map("pieza")
}

model Disfraz {
  id_disfraz  BigInt          @id @default(autoincrement())
  nombre      String          @db.VarChar(100)
  descripcion String?
  deleted_at  DateTime?
  imagenes    DisfrazImagen[]
  piezas      DisfrazPieza[]

  @@map("disfraz")
}

model PiezaCategoria {
  id_pieza_categoria  BigInt          @id @default(autoincrement())
  id_pieza            BigInt
  id_categoria_motivo BigInt
  categoriaMotivo     CategoriaMotivo @relation(fields: [id_categoria_motivo], references: [id_categoria_motivo])
  pieza               Pieza           @relation(fields: [id_pieza], references: [id_pieza])

  @@unique([id_pieza, id_categoria_motivo])
  @@map("pieza_categoria")
}

model DisfrazPieza {
  id_disfraz_pieza BigInt  @id @default(autoincrement())
  id_disfraz       BigInt
  id_pieza         BigInt
  disfraz          Disfraz @relation(fields: [id_disfraz], references: [id_disfraz])
  pieza            Pieza   @relation(fields: [id_pieza], references: [id_pieza])

  @@unique([id_disfraz, id_pieza])
  @@map("disfraz_pieza")
}

model PiezaStock {
  id_pieza_stock     BigInt             @id @default(autoincrement())
  id_pieza           BigInt
  talle              String?            @db.VarChar(20)
  medidas            String?
  estado_pieza_stock EstadoPiezaStock   @default(DISPONIBLE)
  descripcion        String?
  deleted_at         DateTime?
  detalles           OperacionDetalle[]
  pieza              Pieza              @relation(fields: [id_pieza], references: [id_pieza])
  imagenes           PiezaStockImagen[]

  @@map("pieza_stock")
}

model Persona {
  id_persona    BigInt                 @id @default(autoincrement())
  documento     String                 @unique @db.VarChar(20)
  nombre        String                 @db.VarChar(100)
  apellido      String                 @db.VarChar(100)
  deleted_at    DateTime?
  cliente       Cliente?
  interacciones InteraccionOperacion[]
  pagos         PagoOperacion[]
  usuario       Usuario?

  @@map("persona")
}

model Rol {
  id_rol      BigInt       @id @default(autoincrement())
  nombre      String       @unique @db.VarChar(60)
  descripcion String?      @db.VarChar(255)
  permisos    RolPermiso[]
  usuarios    Usuario[]

  @@map("rol")
}

model Permiso {
  id_permiso  BigInt       @id @default(autoincrement())
  nombre      String       @unique @db.VarChar(80)
  descripcion String?      @db.VarChar(255)
  roles       RolPermiso[]

  @@map("permiso")
}

model RolPermiso {
  id_rol     BigInt
  id_permiso BigInt
  permiso    Permiso @relation(fields: [id_permiso], references: [id_permiso])
  rol        Rol     @relation(fields: [id_rol], references: [id_rol])

  @@id([id_rol, id_permiso])
  @@map("rol_permiso")
}

model Usuario {
  id_usuario    BigInt                 @id @default(autoincrement())
  id_persona    BigInt                 @unique
  id_rol        BigInt
  correo        String                 @unique @db.VarChar(100)
  contrasena    String
  deleted_at    DateTime?
  foto_url      String?
  interacciones InteraccionOperacion[]
  persona       Persona                @relation(fields: [id_persona], references: [id_persona])
  rol           Rol                    @relation(fields: [id_rol], references: [id_rol])

  @@map("usuario")
}

model Cliente {
  id_cliente  BigInt      @id @default(autoincrement())
  id_persona  BigInt      @unique
  domicilio   String?     @db.VarChar(255)
  telefono    String      @db.VarChar(50)
  fecha_alta  DateTime    @default(now()) @db.Date
  motivo_baja String?     @db.VarChar(255)
  deleted_at  DateTime?
  persona     Persona     @relation(fields: [id_persona], references: [id_persona])
  operaciones Operacion[]

  @@map("cliente")
}

model Operacion {
  id_operacion       BigInt                 @id @default(autoincrement())
  id_cliente         BigInt
  fecha_constitucion DateTime               @default(now())
  fecha_retiro       DateTime?
  monto_total        Decimal                @default(0) @db.Decimal(12, 2)
  observaciones      String?
  deleted_at         DateTime?
  alquiler           Alquiler?
  interacciones      InteraccionOperacion[]
  cliente            Cliente                @relation(fields: [id_cliente], references: [id_cliente])
  detalles           OperacionDetalle[]
  pagos              PagoOperacion[]
  venta              Venta?

  @@map("operacion")
}

model OperacionDetalle {
  id_operacion_detalle BigInt     @id @default(autoincrement())
  id_operacion         BigInt
  id_pieza_stock       BigInt
  operacion            Operacion  @relation(fields: [id_operacion], references: [id_operacion])
  piezaStock           PiezaStock @relation(fields: [id_pieza_stock], references: [id_pieza_stock])

  @@unique([id_operacion, id_pieza_stock])
  @@map("operacion_detalle")
}

model Alquiler {
  id_alquiler               BigInt        @id @default(autoincrement())
  id_operacion              BigInt        @unique
  etapa                     EtapaAlquiler @default(RESERVADO)
  fecha_devolucion          DateTime?
  deposito_monto            Decimal       @default(0) @db.Decimal(12, 2)
  deposito_devuelto_monto   Decimal       @default(0) @db.Decimal(12, 2)
  deposito_motivo_retencion String?       @db.VarChar(255)
  operacion                 Operacion     @relation(fields: [id_operacion], references: [id_operacion])

  @@map("alquiler")
}

model Venta {
  id_venta                 BigInt     @id @default(autoincrement())
  id_operacion             BigInt     @unique
  etapa                    EtapaVenta @default(RESERVADO)
  especificaciones_medidas String?
  sena_monto               Decimal    @default(0) @db.Decimal(12, 2)
  operacion                Operacion  @relation(fields: [id_operacion], references: [id_operacion])

  @@map("venta")
}

model InteraccionOperacion {
  id_interaccion_operacion BigInt          @id @default(autoincrement())
  id_usuario               BigInt
  id_persona               BigInt
  id_operacion             BigInt
  tipo                     TipoInteraccion
  fecha_hora               DateTime        @default(now())
  observaciones            String?
  deleted_at               DateTime?
  operacion                Operacion       @relation(fields: [id_operacion], references: [id_operacion])
  persona                  Persona         @relation(fields: [id_persona], references: [id_persona])
  usuario                  Usuario         @relation(fields: [id_usuario], references: [id_usuario])

  @@map("interaccion_operacion")
}

model PagoOperacion {
  id_pago_operacion BigInt     @id @default(autoincrement())
  id_persona        BigInt
  id_operacion      BigInt
  tipo              TipoPago
  metodo            MetodoPago
  monto             Decimal    @db.Decimal(12, 2)
  fecha             DateTime   @default(now())
  deleted_at        DateTime?
  operacion         Operacion  @relation(fields: [id_operacion], references: [id_operacion])
  persona           Persona    @relation(fields: [id_persona], references: [id_persona])

  @@map("pago_operacion")
}

model Imagen {
  id_imagen     BigInt                  @id @default(autoincrement())
  url           String
  thumbnail_url String?
  texto_alt     String?                 @db.VarChar(255)
  fecha_subida  DateTime                @default(now())
  deleted_at    DateTime?
  categorias    CategoriaMotivoImagen[]
  disfraces     DisfrazImagen[]
  piezas        PiezaImagen[]
  stocks        PiezaStockImagen[]

  @@map("imagen")
}

model PiezaImagen {
  id_pieza_imagen BigInt  @id @default(autoincrement())
  id_pieza        BigInt
  id_imagen       BigInt
  es_principal    Boolean @default(false)
  orden           Int     @default(0) @db.SmallInt
  imagen          Imagen  @relation(fields: [id_imagen], references: [id_imagen])
  pieza           Pieza   @relation(fields: [id_pieza], references: [id_pieza])

  @@unique([id_pieza, id_imagen])
  @@map("pieza_imagen")
}

model PiezaStockImagen {
  id_pieza_stock_imagen BigInt     @id @default(autoincrement())
  id_pieza_stock        BigInt
  id_imagen             BigInt
  es_principal          Boolean    @default(false)
  orden                 Int        @default(0) @db.SmallInt
  imagen                Imagen     @relation(fields: [id_imagen], references: [id_imagen])
  piezaStock            PiezaStock @relation(fields: [id_pieza_stock], references: [id_pieza_stock])

  @@unique([id_pieza_stock, id_imagen])
  @@map("pieza_stock_imagen")
}

model DisfrazImagen {
  id_disfraz_imagen BigInt  @id @default(autoincrement())
  id_disfraz        BigInt
  id_imagen         BigInt
  es_principal      Boolean @default(false)
  orden             Int     @default(0) @db.SmallInt
  disfraz           Disfraz @relation(fields: [id_disfraz], references: [id_disfraz])
  imagen            Imagen  @relation(fields: [id_imagen], references: [id_imagen])

  @@unique([id_disfraz, id_imagen])
  @@map("disfraz_imagen")
}

model CategoriaMotivoImagen {
  id_categoria_motivo_imagen BigInt          @id @default(autoincrement())
  id_categoria_motivo        BigInt
  id_imagen                  BigInt
  es_principal               Boolean         @default(false)
  categoriaMotivo            CategoriaMotivo @relation(fields: [id_categoria_motivo], references: [id_categoria_motivo])
  imagen                     Imagen          @relation(fields: [id_imagen], references: [id_imagen])

  @@unique([id_categoria_motivo, id_imagen])
  @@map("categoria_motivo_imagen")
}

view v_disfraz_publico {
  id_disfraz       BigInt    @id
  nombre           String    @db.VarChar(100)
  descripcion      String?
  imagen_principal String?
  categorias       Json
  talles           Json
  disponibilidad   String
  deleted_at       DateTime?

  @@map("v_disfraz_publico")
}

/// The underlying view does not contain a valid unique identifier and can therefore currently not be handled by Prisma Client.
view v_recent_movements {
  id_interaccion_operacion BigInt?
  status_raw               TipoInteraccion?
  status                   String?
  item_name                String?          @db.VarChar(100)
  item_size                String?          @db.VarChar(20)
  item_id                  String?
  customer_name            String?
  employee_name            String?
  employee_initials        String?
  time_ago                 DateTime?

  @@ignore
}

/// The underlying view does not contain a valid unique identifier and can therefore currently not be handled by Prisma Client.
view v_active_operations_details {
  id_operacion BigInt?
  cliente      String?
  tipo         String?
  etapa        String?
  fecha        DateTime?
  es_atrasado  Boolean?
  fecha_fin    DateTime? @db.Timestamp(6)

  @@ignore
}

enum EstadoPiezaStock {
  DISPONIBLE
  RESERVADA
  ALQUILADA
  VENDIDA
  FUERA_DE_SERVICIO
  DE_BAJA @map("DE BAJA")
}

enum EtapaAlquiler {
  RESERVADO
  LISTO_PARA_RETIRO
  RETIRADO
  DEVUELTO
  CANCELADO
}

enum EtapaVenta {
  RESERVADO
  LISTO_PARA_ENTREGA
  VENDIDO
  CANCELADO
}

enum TipoInteraccion {
  RETIRO
  DEVOLUCION
  OTRA
}

enum TipoPago {
  SENA
  DEPOSITO
  SALDO
  DEVOLUCION_DEPOSITO
  AJUSTE
}

enum MetodoPago {
  EFECTIVO
  TRANSFERENCIA
}
